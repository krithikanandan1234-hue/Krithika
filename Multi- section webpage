<!DOCTYPE html>
<html>
<head>
<title>Multi Section Webpage</title>

<style>
body{
font-family: Arial;
margin:0;
}

nav{
background:#333;
padding:10px;
text-align:center;
}

nav a{
color:white;
margin:15px;
text-decoration:none;
font-size:18px;
}

section{
padding:60px;
text-align:center;
}

#home{background:#f4f4f4;}
#about{background:#e2e2e2;}
#contact{background:#d0d0d0;}

button{
padding:10px 20px;
font-size:16px;
background:#333;
color:white;
border:none;
cursor:pointer;
}
</style>

</head>

<body>

<nav>
<a href="#home">Home</a>
<a href="#about">About</a>
<a href="#contact">Contact</a>
</nav>

<section id="home">
<h1>Welcome</h1>
<p>This is a basic multi section webpage created using HTML, CSS and JavaScript.</p>
<button onclick="showMessage()">Click Me</button>
</section>

<section id="about">
<h1>About</h1>
<p>This webpage demonstrates how content can be divided into multiple sections for better user experience.</p>
</section>

<section id="contact">
<h1>Contact</h1>
<p>Email: example@email.com</p>
</section>

<script>
function showMessage(){
alert("Welcome to the Multi Section Webpage Project!");
}
</script>

</body>
</html>
